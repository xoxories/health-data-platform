# =====================================================================
# Root .env — read by Hardhat (via dotenv in hardhat.config.js).
# Copy this file to `.env` (which is git-ignored) and fill in the values.
# Frontend env vars live in frontend/.env (see frontend/.env.example).
# =====================================================================

# Alchemy (or other JSON-RPC) endpoint for the Ethereum Sepolia testnet.
# Used as the network URL for `npm run deploy:sepolia`.
# Get one for free at https://www.alchemy.com/ — create an app on Sepolia.
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key_here

# Private key of the deployer wallet (NEVER commit a real key).
# Must be a Sepolia-funded EOA. Used only for `deploy:sepolia`; local
# Hardhat deploys use the in-process funded accounts.
PRIVATE_KEY=your_deployer_private_key_here

# Etherscan API key — enables `npx hardhat verify` if you choose to verify
# the deployed contracts. Optional for local-only development.
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# CoinMarketCap API key — enables USD pricing in the gas report.
# Optional; gas report is generated either way.
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here
