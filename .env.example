# Ethereum Sepolia Testnet RPC URL (e.g. from Alchemy or Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key of the deployer wallet (NEVER commit a real key)
PRIVATE_KEY=0xyourprivatekeyhere

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# CoinMarketCap API key for gas reporter (optional)
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Pinata IPFS credentials (used by the frontend)
VITE_PINATA_API_KEY=your_pinata_api_key
VITE_PINATA_SECRET_API_KEY=your_pinata_secret_api_key
VITE_PINATA_JWT=your_pinata_jwt

# Deployed contract addresses (filled in after deploy)
VITE_PATIENT_REGISTRY_ADDRESS=
VITE_HEALTH_RECORD_STORAGE_ADDRESS=
VITE_CONSENT_MANAGER_ADDRESS=
