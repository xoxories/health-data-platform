# =====================================================================
# Frontend .env — read by Vite at build/dev time as `import.meta.env.*`.
# Copy this file to `frontend/.env` (which is git-ignored) and fill in
# the values. Only VITE_-prefixed variables are exposed to client code.
#
# Contract addresses are NOT configured here — they are auto-written
# into `frontend/src/config/contract.js` by `scripts/deploy.js` after
# each deploy. Do not edit that file by hand.
# =====================================================================

# Pinata IPFS API credentials. Used to pin encrypted record blobs from
# the browser. Create a key at https://app.pinata.cloud/developers/api-keys
# with `pinFileToIPFS` + `pinJSONToIPFS` enabled.
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_API_SECRET=your_pinata_api_secret_here

# Optional: dedicated Pinata gateway hostname (e.g. mygateway.mypinata.cloud).
# When set, encrypted blobs are fetched from this gateway first, then the
# shared Pinata gateway, then ipfs.io. Leave blank to use only the public
# gateways.
VITE_PINATA_GATEWAY=
